import networkx as nx
import numpy as np

def simulate_sir_on_graph(G, R0, recovery_rate=0.1):
    # Calculate transmission rate (beta) based on R0 and average degree (k)
    # R0 = beta / recovery_rate * <k>
    avg_degree = sum(dict(G.degree()).values()) / len(G)
    transmission_rate = (R0 * recovery_rate) / avg_degree
    
    # Simple SIR Logic
    states = {node: 'S' for node in G.nodes()}
    # Seed the infection
    initial_infected = list(G.nodes())[0]
    states[initial_infected] = 'I'
    
    # ... rest of your simulation loop ...
    return states

