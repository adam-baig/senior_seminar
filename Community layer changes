def compare_static_vs_temporal():
    print("  Running static baseline...")
    G_s, _, _ = build_network(seed=RANDOM_SEED)

    static_hist = []
    def c_s():
        return (sum(1 for n in G_s.nodes() if G_s.nodes[n]["state"] == "S"),
                sum(1 for n in G_s.nodes() if G_s.nodes[n]["state"] == "I"),
                sum(1 for n in G_s.nodes() if G_s.nodes[n]["state"] == "R"))

    s, i, r = c_s()
    static_hist.append({"step": 0, "I": i})
    for t in range(1, MAX_STEPS + 1):
        ns = {n: G_s.nodes[n]["state"] for n in G_s.nodes()}
        for u, v, data in G_s.edges(data=True):
            beta = BETA_BY_LAYER.get(data.get("layer","household"), 0.05)
            if G_s.nodes[u]["state"] == "I" and G_s.nodes[v]["state"] == "S":
                if random.random() < beta: ns[v] = "I"
            if G_s.nodes[v]["state"] == "I" and G_s.nodes[u]["state"] == "S":
                if random.random() < beta: ns[u] = "I"
        for n in G_s.nodes():
            if G_s.nodes[n]["state"] == "I":
                if random.random() < GAMMA: ns[n] = "R"
        for n in G_s.nodes():
            G_s.nodes[n]["state"] = ns[n]
        s, i, r = c_s()
        static_hist.append({"step": t, "I": i})
        if i == 0: break

    print("  Running temporal model...")
    G_t, _, _ = build_network(seed=RANDOM_SEED)
    temp_hist, _, _ = run_simulation(G_t)

    df_s = pd.DataFrame(static_hist)
    df_t = pd.DataFrame(temp_hist)

    fig, ax = plt.subplots(figsize=(11, 5))
    t_max = max(df_s["step"].max(), df_t["step"].max())
    for start in range(0, t_max + 1, 7):
        ax.axvspan(start + 5, min(start + 7, t_max),
                   color="#EBEBEB", alpha=0.5, zorder=0)

    ax.plot(df_s["step"], df_s["I"], color="#888780", lw=2, ls="--",
            label="Static model (all edges always active)")
    ax.plot(df_t["step"], df_t["I"] + df_t["L"], color=STATE_COLORS["I"],
            lw=2, label="Temporal model (I + L combined)")

    handles = [
        Line2D([0],[0], color="#888780", lw=2, ls="--",
               label="Static model"),
        Line2D([0],[0], color=STATE_COLORS["I"], lw=2,
               label="Temporal model (I + L)"),
        mpatches.Patch(color="#EBEBEB", alpha=0.7, label="Weekend"),
    ]
    ax.legend(handles=handles, fontsize=10)
    ax.set_xlabel("Day", fontsize=11)
    ax.set_ylabel("Infectious nodes", fontsize=11)
    ax.set_title("Static vs Temporal SIRL — Total Infectious Over Time",
                 fontsize=12)
    ax.set_xlim(0)
    ax.set_ylim(0)
    plt.tight_layout()
    plt.savefig("static_vs_temporal.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("Saved: static_vs_temporal.png")


