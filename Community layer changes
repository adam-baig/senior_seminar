        layer_ec[l] = layer_ec.get(l, 0) + 1
    for l, c in layer_ec.items():
        print(f"        {l:14s} edges: {c}")

    children = [n for n in G.nodes() if G.nodes[n]["type"] == "child"]
    if children:
        acts = [G.nodes[n]["social_activity"] for n in children]
        print(f"        Child social activity: "
              f"mean={np.mean(acts):.2f}  "
              f"min={min(acts):.2f}  max={max(acts):.2f}")

    print("\n[2/8] Drawing layer-by-layer network structure...")
    draw_static_network(G, pos)

    print("\n[3/8] Plotting child activity distribution...")
    plot_child_activity_distribution(G)

    print("\n[4/8] Running SIRL simulation...")
    history, states_over_time, layer_totals = run_simulation(G)
    peak_i = max(h["I"] for h in history)
    peak_l = max(h["L"] for h in history)
    print(f"      Peak infected (I):    {peak_i}/{N}  ({100*peak_i/N:.1f}%)")
    print(f"      Peak on leave  (L):   {peak_l}/{N}  ({100*peak_l/N:.1f}%)")

    print("\n[5/8] Plotting SIRL curves + layer breakdown...")
    plot_sir_curves(history)
    plot_layer_breakdown(layer_totals)

    print("\n[6/8] Degree distribution + contact intensity...")
    plot_degree_distribution(G)
    plot_contact_intensity(G)

    print("\n[7/8] Comparison figures...")
    compare_static_vs_temporal()
    plot_sick_leave_comparison()

    export_csv(history, layer_totals)

    print("\n[8/8] Launching animation...")
    print("      Space = play/pause     R = reset")
    animate_sir(G, pos, states_over_time, history)
    print("\nOutput files:")
    for f in ["network_layers.png",       "child_activity_dist.png",
              "sirl_curves.png",           "layer_breakdown.png",
              "degree_distribution.png",   "contact_intensity.png",
              "static_vs_temporal.png",    "sick_leave_comparison.png",
              "sir_animation.gif",         "sirl_data.csv"]:
        print(f"  {f}")