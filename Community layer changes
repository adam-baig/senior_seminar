def _run_with_leave_prob(G, leave_prob):
    """Helper — runs simulation with a custom sick leave probability."""
    history = []

    def counts():
        s = sum(1 for n in G.nodes() if G.nodes[n]["state"] == "S")
        i = sum(1 for n in G.nodes() if G.nodes[n]["state"] == "I")
        l = sum(1 for n in G.nodes() if G.nodes[n]["state"] == "L")
        r = sum(1 for n in G.nodes() if G.nodes[n]["state"] == "R")
        return s, i, l, r

    s, i, l, r = counts()
    history.append({"step": 0, "S": s, "I": i, "L": l, "R": r})

    for t in range(1, MAX_STEPS + 1):
        phase      = get_phase(t)
        new_states = {n: G.nodes[n]["state"] for n in G.nodes()}
        new_ldays  = {n: G.nodes[n]["leave_days"] for n in G.nodes()}
        new_asymptomatic_days = {n: G.nodes[n]["asymptomatic_days"]  for n in G.nodes()}

        for u, v, data in G.edges(data=True):
            layer = data.get("layer", "household")
            if not edge_is_active(layer, phase):
                continue
            u_on_leave = G.nodes[u]["state"] == "L"
            v_on_leave = G.nodes[v]["state"] == "L"
            if layer in ("work", "school", "social_weekend"):
                if u_on_leave or v_on_leave:
                    continue
            beta = BETA_BY_LAYER.get(layer, 0.0)
            if layer in ("school", "social_weekend"):
                a_u  = G.nodes[u].get("social_activity", 1.0)
                a_v  = G.nodes[v].get("social_activity", 1.0)
                beta = beta * (a_u + a_v) / 2
            u_inf = G.nodes[u]["state"] in ("I", "L")
            v_inf = G.nodes[v]["state"] in ("I", "L")
            if u_inf and G.nodes[v]["state"] == "S":
                if random.random() < beta:
                    new_states[v] = "I"
            if v_inf and G.nodes[u]["state"] == "S":
                if random.random() < beta:
                    new_states[u] = "I"

        for n in G.nodes():
            state = G.nodes[n]["state"]
            if state == "I":
                if random.random() < leave_prob:
                    new_states[n] = "L"
                    new_ldays[n]  = 1
                elif random.random() < GAMMA:
                    new_states[n] = "R"
            elif state == "L":
                days = G.nodes[n]["leave_days"] + 1
                if days >= SICK_LEAVE_DURATION or random.random() < GAMMA_ON_LEAVE:
                    new_states[n] = "R"
                    new_ldays[n]  = 0
                else:
                    new_ldays[n] = days

        for n in G.nodes():
            G.nodes[n]["state"]      = new_states[n]
            G.nodes[n]["leave_days"] = new_ldays[n]
            G.nodes[n]["asymptomatic_days"]  = new_asymptomatic_days[n]

        s, i, l, r = counts()
        history.append({"step": t, "S": s, "I": i, "L": l, "R": r})
        if i == 0 and l == 0:
            break

    return history


