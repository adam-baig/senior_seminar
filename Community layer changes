def compute_contact_intensity(G):
    intensity = {}
    for phase in ("weekday", "weekend"):
        intensity[phase] = {
            n: sum(1 for nbr in G.neighbors(n)
                   if edge_is_active(G[n][nbr].get("layer","household"), phase))
            for n in G.nodes()
        }
    return intensity


